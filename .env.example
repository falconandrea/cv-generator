# AI Provider Configuration
# Copy to .env.local and fill in your values

# OpenAI-compatible base URL (e.g. DeepSeek, OpenAI, Ollama, etc.)
AI_PROVIDER_BASE_URL=https://api.deepseek.com/v1
# Your API key for the provider above
AI_PROVIDER_API_KEY=your-api-key-here
# Model to use (e.g. deepseek-chat, gpt-4o, llama3)
AI_PROVIDER_MODEL=deepseek-chat
